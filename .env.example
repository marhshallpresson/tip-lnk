# ─── SOLANA & INFRASTRUCTURE ───
VITE_SOLANA_NETWORK=mainnet-beta # devnet or mainnet-beta
VITE_SOLANA_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your-key
SECONDARY_RPC_URL=https://solana-mainnet.rpc.extnode.com
HELIUS_API_KEY=your-helius-key
HELIUS_WEBHOOK_ID=your-webhook-id
HELIUS_WEBHOOK_SECRET=your-webhook-secret
QUICKNODE_RPC_URL=your-quicknode-url
VITE_DFLOW_API_KEY=

# ─── DATABASE & CACHING (SUPABASE + UPSTASH) ───
DATABASE_URL=postgres://postgres.your-project:password@aws-0-us-east-1.pooler.supabase.com:6543/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# ─── IDENTITY & AUTH (DYNAMIC.XYZ + SOCIALS) ───
VITE_DYNAMIC_ENVIRONMENT_ID=your-dynamic-env-id
JWT_SECRET=your-jwt-secret
SESSION_TOKEN_SECRET=your-session-secret
COOKIE_SAMESITE=lax # lax, strict, or none
VITE_X_CLIENT_ID=your-x-client-id
VITE_DISCORD_CLIENT_ID=your-discord-client-id
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# ─── PAYMENTS & OFFRAMPS (FOSSA + PAJCASH) ───
VITE_TREASURY_WALLET=your-treasury-pubkey
FOSSA_API_KEY=your-fossa-api-key
FOSSA_BASE_URL=https://api.fossapay.com
FOSSA_WEBHOOK_SECRET=your-fossa-webhook-secret
PAJCASH_API_KEY=your-pajcash-api-key
PAJCASH_BASE_URL=https://api.pajcash.com
PAJCASH_WEBHOOK_SECRET=your-pajcash-webhook-secret
JUPITER_API_KEY=your-jupiter-api-key

# ─── MARKET INTELLIGENCE (BIRDEYE) ───
BIRDEYE_API_KEY=your-birdeye-key

# ─── GROWTH & TRACKING (TORQUE MCP) ───
TORQUE_API_URL=https://api.torquemarketing.xyz/api/events
TORQUE_API_KEY=your-torque-key

# ─── MAILER (BREVO / SMTP) ───
MAIL_HOST=smtp-relay.brevo.com
MAIL_PORT=587
MAIL_USER=your-email@example.com
MAIL_PASS=your-smtp-password
MAIL_FROM=noreply@tipstack.fun
MAIL_ASSET_URL=https://tipstack.fun/assets/mail

# ─── APP CONFIG ───
NODE_ENV=development # development or production
VITE_APP_URL=http://localhost:5173
VITE_API_BASE_URL=http://localhost:3001
CORS_ALLOWED_ORIGINS=http://localhost:5173,https://tipstack.fun

# ─── ADMIN ───
ADMIN_EMAIL=admin@tipstack.fun
ADMIN_SECRET=your-super-secret-admin-key
