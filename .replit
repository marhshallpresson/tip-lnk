modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 24013
externalPort = 80

[userenv]

[userenv.shared]
SESSION_TOKEN_SECRET = "604efe8433a11ace0f4347964cb2ff2ca56349560effa2be6877a2a8bc6e7277"
VITE_API_BASE_URL = ""
